# Paths
DATASET_PATH=datasets/dataset.csv
CLEANED_DATASET_PATH=datasets/cleaned_dataset.csv
EMBEDDINGS_OUTPUT_DIR=models/embeddings

# Shared split controls
EMBEDDING_TEXT_COLUMN=text
EMBEDDING_LABEL_COLUMN=label
EMBEDDING_TEST_SIZE=0.2
EMBEDDING_RANDOM_STATE=42
EMBEDDING_STRATIFY=true
EMBEDDING_FORCE_RERUN=false

# Runs to execute
EMBEDDING_TYPES=bow_unigram,bow_bigram,bow_unigram_bigram,tfidf_unigram,tfidf_bigram,tfidf_unigram_bigram,word2vec_skipgram,word2vec_cbow,glove_300d,fasttext_skipgram,fasttext_cbow

# Bag of Words
EMBEDDING__BOW_UNIGRAM__TYPE=bow
EMBEDDING__BOW_UNIGRAM__NGRAM_RANGE=1,1
EMBEDDING__BOW_UNIGRAM__MAX_FEATURES=null
EMBEDDING__BOW_UNIGRAM__MIN_DF=1
EMBEDDING__BOW_UNIGRAM__MAX_DF=1.0

EMBEDDING__BOW_BIGRAM__TYPE=bow
EMBEDDING__BOW_BIGRAM__NGRAM_RANGE=2,2
EMBEDDING__BOW_BIGRAM__MAX_FEATURES=null
EMBEDDING__BOW_BIGRAM__MIN_DF=1
EMBEDDING__BOW_BIGRAM__MAX_DF=1.0

EMBEDDING__BOW_UNIGRAM_BIGRAM__TYPE=bow
EMBEDDING__BOW_UNIGRAM_BIGRAM__NGRAM_RANGE=1,2
EMBEDDING__BOW_UNIGRAM_BIGRAM__MAX_FEATURES=null
EMBEDDING__BOW_UNIGRAM_BIGRAM__MIN_DF=1
EMBEDDING__BOW_UNIGRAM_BIGRAM__MAX_DF=1.0

# TF-IDF
EMBEDDING__TFIDF_UNIGRAM__TYPE=tfidf
EMBEDDING__TFIDF_UNIGRAM__NGRAM_RANGE=1,1
EMBEDDING__TFIDF_UNIGRAM__MAX_FEATURES=null
EMBEDDING__TFIDF_UNIGRAM__MIN_DF=1
EMBEDDING__TFIDF_UNIGRAM__MAX_DF=1.0

EMBEDDING__TFIDF_BIGRAM__TYPE=tfidf
EMBEDDING__TFIDF_BIGRAM__NGRAM_RANGE=2,2
EMBEDDING__TFIDF_BIGRAM__MAX_FEATURES=null
EMBEDDING__TFIDF_BIGRAM__MIN_DF=1
EMBEDDING__TFIDF_BIGRAM__MAX_DF=1.0

EMBEDDING__TFIDF_UNIGRAM_BIGRAM__TYPE=tfidf
EMBEDDING__TFIDF_UNIGRAM_BIGRAM__NGRAM_RANGE=1,2
EMBEDDING__TFIDF_UNIGRAM_BIGRAM__MAX_FEATURES=null
EMBEDDING__TFIDF_UNIGRAM_BIGRAM__MIN_DF=1
EMBEDDING__TFIDF_UNIGRAM_BIGRAM__MAX_DF=1.0

# Word2Vec
EMBEDDING__WORD2VEC_SKIPGRAM__TYPE=word2vec
EMBEDDING__WORD2VEC_SKIPGRAM__VECTOR_SIZE=300
EMBEDDING__WORD2VEC_SKIPGRAM__WINDOW=5
EMBEDDING__WORD2VEC_SKIPGRAM__MIN_COUNT=1
EMBEDDING__WORD2VEC_SKIPGRAM__WORKERS=4
EMBEDDING__WORD2VEC_SKIPGRAM__SG=1
EMBEDDING__WORD2VEC_SKIPGRAM__EPOCHS=5

EMBEDDING__WORD2VEC_CBOW__TYPE=word2vec
EMBEDDING__WORD2VEC_CBOW__VECTOR_SIZE=300
EMBEDDING__WORD2VEC_CBOW__WINDOW=5
EMBEDDING__WORD2VEC_CBOW__MIN_COUNT=1
EMBEDDING__WORD2VEC_CBOW__WORKERS=4
EMBEDDING__WORD2VEC_CBOW__SG=0
EMBEDDING__WORD2VEC_CBOW__EPOCHS=5

# GloVe
EMBEDDING__GLOVE_300D__TYPE=glove
EMBEDDING__GLOVE_300D__GLOVE_FILE_PATH=embeddings/glove/glove.6B.300d.txt
EMBEDDING__GLOVE_300D__VECTOR_SIZE=300

# FastText
EMBEDDING__FASTTEXT_SKIPGRAM__TYPE=fasttext
EMBEDDING__FASTTEXT_SKIPGRAM__VECTOR_SIZE=300
EMBEDDING__FASTTEXT_SKIPGRAM__WINDOW=5
EMBEDDING__FASTTEXT_SKIPGRAM__MIN_COUNT=1
EMBEDDING__FASTTEXT_SKIPGRAM__WORKERS=4
EMBEDDING__FASTTEXT_SKIPGRAM__SG=1
EMBEDDING__FASTTEXT_SKIPGRAM__EPOCHS=5

EMBEDDING__FASTTEXT_CBOW__TYPE=fasttext
EMBEDDING__FASTTEXT_CBOW__VECTOR_SIZE=300
EMBEDDING__FASTTEXT_CBOW__WINDOW=5
EMBEDDING__FASTTEXT_CBOW__MIN_COUNT=1
EMBEDDING__FASTTEXT_CBOW__WORKERS=4
EMBEDDING__FASTTEXT_CBOW__SG=0
EMBEDDING__FASTTEXT_CBOW__EPOCHS=5

# ML Pipeline
ML_EMBEDDING_RUN_PATH=models/embeddings/dd5c60e10afe7b51
ML_OUTPUT_DIR=models/ml_models
ML_RANDOM_STATE=42
ML_FORCE_RERUN=false
ML_EMBEDDING_TYPES=bow_unigram,bow_bigram,bow_unigram_bigram,tfidf_unigram,tfidf_bigram,tfidf_unigram_bigram,word2vec_skipgram,word2vec_cbow,glove_300d,fasttext_skipgram,fasttext_cbow
# Classifiers to execute
ML_TYPES=logistic_regression,svm,random_forest,xgboost,decision_tree

# Logistic Regression
ML__LOGISTIC_REGRESSION__TYPE=logistic_regression
ML__LOGISTIC_REGRESSION__MAX_ITER=1000
ML__LOGISTIC_REGRESSION__C=1.0
ML__LOGISTIC_REGRESSION__SOLVER=lbfgs
ML__LOGISTIC_REGRESSION__MULTI_CLASS=auto

# Support Vector Machine (SVC)
ML__SVM__TYPE=svm
ML__SVM__KERNEL=rbf
ML__SVM__C=1.0
ML__SVM__GAMMA=scale
ML__SVM__PROBABILITY=false

# Random Forest
ML__RANDOM_FOREST__TYPE=random_forest
ML__RANDOM_FOREST__N_ESTIMATORS=300
ML__RANDOM_FOREST__MAX_DEPTH=null
ML__RANDOM_FOREST__MIN_SAMPLES_SPLIT=2
ML__RANDOM_FOREST__MIN_SAMPLES_LEAF=1

# XGBoost
ML__XGBOOST__TYPE=xgboost
ML__XGBOOST__N_ESTIMATORS=300
ML__XGBOOST__MAX_DEPTH=6
ML__XGBOOST__LEARNING_RATE=0.1
ML__XGBOOST__SUBSAMPLE=1.0
ML__XGBOOST__COLSAMPLE_BYTREE=1.0
ML__XGBOOST__REG_ALPHA=0.0
ML__XGBOOST__REG_LAMBDA=1.0

# Decision Tree
ML__DECISION_TREE__TYPE=decision_tree
ML__DECISION_TREE__MAX_DEPTH=null
ML__DECISION_TREE__MIN_SAMPLES_SPLIT=2
ML__DECISION_TREE__MIN_SAMPLES_LEAF=1
